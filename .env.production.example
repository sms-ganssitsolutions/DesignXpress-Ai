# Production Environment Variables for DesignXpress AI

# Database
DB_USER=designxpress
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DB_NAME=designxpress_ai

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING

# AI Keys (required for real AI features)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=

# URLs
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# FFmpeg path inside container (usually not needed)
FFMPEG_PATH=/usr/bin/ffmpeg
