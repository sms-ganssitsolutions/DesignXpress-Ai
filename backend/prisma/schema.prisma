// ===========================================
// DESIGNXPRESS AI STORY VIDEO STUDIO
// Prisma Schema - PostgreSQL
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  avatarUrl     String?
  role          String    @default("user") // user | admin | team_member
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  projects      Project[]
  aiRequests    AIRequest[]
  exportJobs    ExportJob[]
  notifications Notification[]
  ownedTeams    Team[]      @relation("TeamOwner")
  teamMembers   TeamMember[]
  subscriptions Subscription[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  duration    Int?     // in seconds
  status      String   @default("draft") // draft | processing | completed | archived
  isPublic    Boolean  @default(false)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  scenes      Scene[]
  assets      Asset[]
  aiRequests  AIRequest[]
  exportJobs  ExportJob[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Scene {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  order       Int      // position in timeline
  title       String
  description String?
  duration    Int      // seconds
  startTime   Float    // seconds from project start

  // Visual content
  backgroundUrl String?
  thumbnailUrl  String?

  // AI generated content
  script        String?
  voiceoverUrl  String?
  voiceId       String?

  layers      Json?    // array of layer objects {id, type, content, position, style}

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("scenes")
}

model Asset {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  type        String   // image | video | audio | font | subtitle
  url         String
  size        Int?
  duration    Float?   // for video/audio
  width       Int?
  height      Int?

  metadata    Json?    // any extra data

  createdAt   DateTime @default(now())

  @@map("assets")
}

model AIRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  type        String   // script | story | voiceover | thumbnail | subtitle | scene
  prompt      String
  result      Json?    // the AI output
  status      String   @default("pending") // pending | processing | completed | failed
  error       String?

  model       String?
  tokensUsed  Int?
  cost        Float?

  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@map("ai_requests")
}

model ExportJob {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])

  status      String   @default("queued") // queued | processing | completed | failed
  progress    Int      @default(0)       // 0-100
  outputUrl   String?
  error       String?
  options     Json?    // musicUrl, resolution, etc.

  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@map("export_jobs")
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  plan          String   // free | pro | studio | enterprise
  status        String   // active | canceled | past_due
  stripeId      String?  @unique

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("subscriptions")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  owner       User     @relation("TeamOwner", fields: [ownerId], references: [id])

  members     TeamMember[]
  createdAt   DateTime @default(now())

  @@map("teams")
}

model TeamMember {
  id      String @id @default(cuid())
  teamId  String
  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  role    String @default("member") // owner | admin | member | viewer

  @@unique([teamId, userId])
  @@map("team_members")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  message   String
  type      String   // info | success | warning | error
  read      Boolean  @default(false)
  link      String?

  createdAt DateTime @default(now())

  @@map("notifications")
}

model Template {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  category    String?  // cinematic | social | corporate | horror | documentary
  prompt      String?  // base prompt used to generate this template
  scenes      Json?    // default scene structure

  isPublic    Boolean  @default(true)
  usageCount  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("templates")
}
